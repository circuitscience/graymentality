RewriteEngine On

# Send every PHP request through the front controller.
RewriteCond %{REQUEST_URI} \.php$ [NC]
RewriteRule ^ index.php [L,QSA]

# Let real files and directories serve normally; everything else becomes a route.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L,QSA]
