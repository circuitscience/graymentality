# Copy to .env.staging on the remote staging host.
APP_ROOT=/var/www/graymentality
APP_ENV=staging
APP_DEBUG=0

MAIN_DOMAIN_URL=https://www.graymentality.ca
LOGIN_URL=https://www.graymentality.ca/login
XFIT_URL=https://xfit.graymentality.ca

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_staging_database
DB_USER=your_staging_user
DB_PASS=change-me
DB_CHARSET=utf8mb4

MAIL_FROM=no-reply@graymentality.ca
MAIL_FROM_NAME=Gray Mentality
MAIL_SMTP_HOST=mail.graymentality.ca
MAIL_SMTP_PORT=465
MAIL_SMTP_ENCRYPTION=tls
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
